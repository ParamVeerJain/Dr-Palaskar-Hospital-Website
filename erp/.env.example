# Copy to .env and change values for your deployment.
# SECRET_KEY: if left empty, a key is generated and persisted to data/.secret_key on first run.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=720
DATABASE_URL=sqlite+aiosqlite:///./data/hospital.db
UPLOAD_DIR=./data/uploads
SEED_ON_STARTUP=1
COOKIE_SECURE=0
RATE_LIMIT_ENABLED=1
